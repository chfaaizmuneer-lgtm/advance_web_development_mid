<%- include('../partials/header') %>

<div class="page-header">
  <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-box me-2 text-primary"></i>Product Details</h1>
    <div class="d-flex gap-2">
      <a href="/products" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
      <a href="/products/<%= product._id %>/edit" class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
      <form action="/products/<%= product._id %>?_method=DELETE" method="POST" class="d-inline">
        <button type="submit" class="btn btn-danger btn-sm btn-delete"><i class="bi bi-trash me-1"></i>Delete</button>
      </form>
    </div>
  </div>
</div>

<div class="container-fluid px-4 pb-4">
  <% if (locals.query && query.success) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle-fill me-2"></i><%= query.success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <div class="row g-4">
    <!-- Product Info Card -->
    <div class="col-md-8">
      <div class="card">
        <div class="card-header bg-white py-3">
          <h5 class="mb-0 fw-semibold"><%= product.name %></h5>
          <code class="text-primary"><%= product.sku %></code>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-sm-6">
              <p class="text-muted small mb-1">Category</p>
              <span class="badge bg-primary"><%= product.category %></span>
            </div>
            <div class="col-sm-6">
              <p class="text-muted small mb-1">Supplier</p>
              <strong><%= product.supplier %></strong>
            </div>
            <div class="col-sm-6">
              <p class="text-muted small mb-1">Price</p>
              <strong class="text-success fs-5">$<%= product.price.toFixed(2) %></strong>
            </div>
            <div class="col-sm-6">
              <p class="text-muted small mb-1">Quantity</p>
              <strong class="fs-5"><%= product.quantity %> units</strong>
            </div>
            <div class="col-sm-6">
              <p class="text-muted small mb-1">Status</p>
              <% if (product.quantity === 0) { %>
                <span class="badge badge-out px-3 py-2">Out of Stock</span>
              <% } else if (product.quantity <= 10) { %>
                <span class="badge badge-low px-3 py-2">Low Stock</span>
              <% } else { %>
                <span class="badge badge-in px-3 py-2">In Stock</span>
              <% } %>
            </div>
            <div class="col-sm-6">
              <p class="text-muted small mb-1">Total Inventory Value</p>
              <strong class="text-primary">$<%= (product.price * product.quantity).toFixed(2) %></strong>
            </div>
            <% if (product.description) { %>
              <div class="col-12">
                <p class="text-muted small mb-1">Description</p>
                <p><%= product.description %></p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Meta Card -->
    <div class="col-md-4">
      <div class="card">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold text-muted">Record Info</h6>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-1">Product ID</p>
          <code class="small"><%= product._id %></code>
          <hr/>
          <p class="text-muted small mb-1">Created At</p>
          <strong class="small"><%= new Date(product.createdAt).toLocaleString() %></strong>
          <hr/>
          <p class="text-muted small mb-1">Last Updated</p>
          <strong class="small"><%= new Date(product.updatedAt).toLocaleString() %></strong>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
