<%- include('../partials/header') %>

<div class="page-header">
  <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-speedometer2 me-2 text-primary"></i>Inventory Dashboard</h1>
    <a href="/products/new" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i>Add Product
    </a>
  </div>
</div>

<div class="container-fluid px-4 pb-4">

  <!-- Success / Error Alert -->
  <% if (locals.query && query.success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i><%= query.success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- ── Stat Cards ─────────────────────────────────────────────── -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background: linear-gradient(135deg,#2563eb,#1d4ed8);">
        <div class="icon"><i class="bi bi-box-seam"></i></div>
        <div>
          <div class="value"><%= stats.total %></div>
          <div class="label">Total Products</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background: linear-gradient(135deg,#d97706,#b45309);">
        <div class="icon"><i class="bi bi-exclamation-triangle"></i></div>
        <div>
          <div class="value"><%= stats.lowStock %></div>
          <div class="label">Low Stock</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background: linear-gradient(135deg,#dc2626,#b91c1c);">
        <div class="icon"><i class="bi bi-x-circle"></i></div>
        <div>
          <div class="value"><%= stats.outOfStock %></div>
          <div class="label">Out of Stock</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card" style="background: linear-gradient(135deg,#16a34a,#15803d);">
        <div class="icon"><i class="bi bi-currency-dollar"></i></div>
        <div>
          <div class="value">$<%= stats.totalValue %></div>
          <div class="label">Inventory Value</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Search & Filters ───────────────────────────────────────── -->
  <div class="card mb-4">
    <div class="card-body py-3">
      <form method="GET" action="/products" class="row g-2 align-items-end">
        <div class="col-12 col-md-5">
          <label class="form-label mb-1">Search</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" name="search" class="form-control" placeholder="Search by name, SKU, or supplier..." value="<%= search %>">
          </div>
        </div>
        <div class="col-6 col-md-3">
          <label class="form-label mb-1">Category</label>
          <select name="category" class="form-select">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= selectedCategory === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-2">
          <label class="form-label mb-1">Stock Status</label>
          <select name="status" class="form-select">
            <option value="all" <%= selectedStatus === 'all' ? 'selected' : '' %>>All</option>
            <option value="in" <%= selectedStatus === 'in' ? 'selected' : '' %>>In Stock</option>
            <option value="low" <%= selectedStatus === 'low' ? 'selected' : '' %>>Low Stock</option>
            <option value="out" <%= selectedStatus === 'out' ? 'selected' : '' %>>Out of Stock</option>
          </select>
        </div>
        <div class="col-12 col-md-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-filter me-1"></i>Filter</button>
          <a href="/products" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Products Table ─────────────────────────────────────────── -->
  <div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
      <h5 class="mb-0 fw-semibold">Products (<%= products.length %>)</h5>
    </div>
    <div class="card-body p-0">
      <% if (products.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <i class="bi bi-inbox display-4"></i>
          <p class="mt-3 mb-1 fw-semibold">No products found</p>
          <p class="small">Try adjusting your filters or <a href="/products/new">add a product</a>.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>SKU</th>
                <th>Category</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Status</th>
                <th>Supplier</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach((product, i) => { %>
                <tr>
                  <td class="text-muted small"><%= i + 1 %></td>
                  <td class="fw-semibold"><%= product.name %></td>
                  <td><code class="text-primary"><%= product.sku %></code></td>
                  <td><span class="badge bg-light text-dark border"><%= product.category %></span></td>
                  <td>$<%= product.price.toFixed(2) %></td>
                  <td><%= product.quantity %></td>
                  <td>
                    <% if (product.quantity === 0) { %>
                      <span class="badge badge-out px-2 py-1">Out of Stock</span>
                    <% } else if (product.quantity <= 10) { %>
                      <span class="badge badge-low px-2 py-1">Low Stock</span>
                    <% } else { %>
                      <span class="badge badge-in px-2 py-1">In Stock</span>
                    <% } %>
                  </td>
                  <td class="text-muted small"><%= product.supplier %></td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/products/<%= product._id %>" class="btn btn-sm btn-outline-primary" title="View">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a href="/products/<%= product._id %>/edit" class="btn btn-sm btn-outline-warning" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form action="/products/<%= product._id %>?_method=DELETE" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger btn-delete" title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
