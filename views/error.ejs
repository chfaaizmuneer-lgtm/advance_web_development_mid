<%- include('./partials/header') %>

<div class="container py-5 text-center">
  <div class="display-1 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
  <h1 class="fw-bold">Something went wrong</h1>
  <p class="text-muted fs-5"><%= message %></p>
  <% if (error && error.stack && process.env.NODE_ENV === 'development') { %>
    <pre class="text-start bg-light p-3 rounded mt-4 small"><%= error.stack %></pre>
  <% } %>
  <a href="/products" class="btn btn-primary mt-3"><i class="bi bi-house me-1"></i>Go to Dashboard</a>
</div>

<%- include('./partials/footer') %>
